# ── HuggingFace Inference Providers (LLM) ────────────────────────────────
# Credits are billed against these tokens. Get one at https://huggingface.co/settings/tokens
# Add more tokens (HF_TOKEN_2, HF_TOKEN_3, ...) to enable round-robin rotation
# with automatic failover across keys.
HF_TOKEN=
HF_TOKEN_2=
HF_TOKEN_3=
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL=deepseek-ai/DeepSeek-V3-0324
HF_MODEL_FAST=meta-llama/Llama-3.3-70B-Instruct
HF_TEMPERATURE=0.2
HF_MAX_TOKENS=2048

# ── Vector store (local, Docker) ─────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=tbcg_kb

# ── Embeddings (local, no spend) ─────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Web search ───────────────────────────────────────────────────────────
SEARCH_BACKEND=ddgs          # ddgs | tavily
TAVILY_API_KEY=              # only if SEARCH_BACKEND=tavily

# ── Workflow controls ────────────────────────────────────────────────────
MAX_REVISIONS=2              # critic <-> strategy loop cap

# ── Observability (optional) ─────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tbcg
# Set the regional endpoint if your LangSmith org is non-US, e.g.:
# https://apac.api.smith.langchain.com  or  https://eu.api.smith.langchain.com
LANGSMITH_ENDPOINT=
